  m_Script: {fileID: 11500000, guid: 2ee2f0ff930005041aebfdb0cc1f832c, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::IntroSequence
  sceneName: Map
  messageText: {fileID: 1089088574}
  uiRoot: {fileID: 1471524629}
  blackPanel: {fileID: 1427249177}
  uiCanvasGroup: {fileID: 0}
  animatedImage: {fileID: 702083471}
  imageSizeStart: {x: 960, y: 540}
  imageSizeEnd: {x: 1344, y: 756}
  messages:
  - message: Hello comrade, welcome to the Center for Digital Evaluation.
    duration: 5
  - message: You've been recruited to aid with the annual citizen evaluation.
    duration: 5
  - message: Your job is to take control of the test subject's media devices, in
      order to sway their mindset to trust our agenda.
    duration: 5
  - message: Remember, the score received by the subject is largely a reflection
      of your own effort.
    duration: 5
  - message: This assessment will run over a span of seven days, after which a final
      score and suggested action will be determined.
    duration: 5
  - message: We expect the highest levels of effort, this position is highly respected,
      and as you know, the pay reflects it.
    duration: 5
  - message: Glory to the Supreme Leader.
    duration: 5
  fadeInDuration: 1
  messageFadeDuration: 0.5
